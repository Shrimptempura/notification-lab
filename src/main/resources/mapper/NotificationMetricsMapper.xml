<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="portfolio.notification_lab.mapper.NotificationMetricsMapper">

    <!-- 상태별 요청 조회 수 -->
    <select id="countByStatus"
            resultType="portfolio.notification_lab.dto.NotificationStatusCountDto">
        SELECT
            status,
            COUNT(*) AS count
        FROM notification_request
        GROUP BY status
        ORDER BY status
    </select>
</mapper>