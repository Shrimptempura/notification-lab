<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="portfolio.notification_lab.mapper.NotificationRequestMapper">

    <!-- 전체 개수 확인 -->
    <select id="countAll"
            resultType="int">

        SELECT count(*)
        FROM notification_request

    </select>

    <!-- 상태별 개수 확인 -->
    <select id="countByStatus"
            resultType="int"
            parameterType="string">

        SELECT count(*)
        FROM notification_request
        WHERE status = #{status}

    </select>

    <!-- 전체 초기화(테스트) -->
    <update id="resetAllToPending">

        UPDATE notification_request
        SET status = 'PENDING',
        retry_count = 0

    </update>

</mapper>
